{
  "name": "orale-cli",
  "version": "0.1.4-alpha",
  "description": "Plan, dispatch, and orchestrate AI coding agents across parallel git worktrees.",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "orale": "./bin/orale.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/storage": "./dist/adapters/storage/index.js",
    "./adapters/agent": "./dist/adapters/agent/index.js"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "keywords": [
    "claude-code",
    "ai",
    "agents",
    "orchestration",
    "git-worktree",
    "kanban",
    "tui",
    "cli",
    "orale"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "orale": "tsx src/cli/index.ts",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^12.0.0",
    "env-paths": "^3.0.0",
    "execa": "^9.0.0",
    "ink": "^5.0.0",
    "p-limit": "^6.0.0",
    "react": "^18.0.0",
    "yaml": "^2.0.0",
    "zod": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
