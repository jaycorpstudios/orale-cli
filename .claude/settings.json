{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint:fix"
          },
          {
            "type": "command",
            "command": "npm run typecheck"
          }
        ]
      }
    ]
  }
}
